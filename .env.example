# ============================================================
# 法律顾问 Agent 配置文件（模板）
# 复制此文件为 .env 并填入你的 API Key
# ============================================================

# --- 日志 ---
LOG_LEVEL=INFO
# LOG_FORMAT=text  # text 或 json

# --- 厂商选择 ---
LLM_PROVIDER=qwen
# DeepSeek 无 Embedding API，使用 Qwen（DashScope）
EMBEDDING_PROVIDER=qwen

# --- Qwen / DashScope ---
QWEN_API_KEY=your-api-key-here
QWEN_CHAT_MODEL=qwen3-max
QWEN_SUMMARY_MODEL=qwen-turbo
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANKER_MODEL=gte-rerank-v2

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# --- 本地 Embedding ---
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
HF_CACHE_DIR=./models_cache

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- 数据库 ---
# PostgreSQL 连接（留空则使用 SQLite）
DATABASE_URL=postgresql://postgres:123456@localhost:5432/lawyer_agents
# 本地运行时 SQLite（DATABASE_URL 留空时使用）：会话、反馈、语义缓存
APP_DB_PATH=./data/db/app.sqlite3

# --- 向量库 & 数据 ---
CHROMA_PERSIST_DIR=./chroma_db
DATA_DIR=./data
# 主法条库启动加载时排除的 data 子目录（逗号分隔）
DATA_EXCLUDE_DIRS=司法解释,指导性案例,official_cases,CaseMatch,db,eval
# 司法解释按需检索：启动只扫文件名，问答/案情分析时读取少量相关文件
ENABLE_INTERPRETATION_RETRIEVAL=true
INTERPRETATION_DIR=./data/司法解释
INTERPRETATION_DB_PATH=./data/db/interpretations.sqlite3
INTERPRETATION_TOP_K=2
INTERPRETATION_CANDIDATE_FILES=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- 混合检索 & Rerank ---
RETRIEVER_TOP_K=5
BM25_TOP_K=20
VECTOR_TOP_K=20
RERANK_TOP_K=20
RERANK_FINAL_K=6
RRF_CONSTANT=60
ADJACENT_RANGE=1
ENABLE_RERANK=true
ENABLE_CLASSIFICATION=true

# --- 多域协作 ---
MULTI_DOMAIN_MAX_DOMAINS=3
ENABLE_WEIGHTED_MERGE=false
DOMAIN_PRIORITY_ORDER=刑事,行政,治安,监察
ENABLE_INTELLIGENT_EXPANSION=false
EXPANSION_DEPTH=1
ENABLE_SEMANTIC_VERIFICATION=false

# --- 案例检索 ---
ENABLE_CASE_RETRIEVAL=true
# 官方精选案例库默认启用；旧 LeCaRD / CaseMatch 历史库默认关闭
USE_OFFICIAL_CASES=true
USE_LEGACY_CASES=false
OFFICIAL_CASE_SOURCE=manual_json
OFFICIAL_CASE_RAW_DIR=./data/official_cases/raw
OFFICIAL_CASE_PROCESSED_FILE=./data/official_cases/processed/official_cases.jsonl
OFFICIAL_CASE_COLLECTION=official_cases
OFFICIAL_CASE_TOP_K=3
LEGACY_CASE_TOP_K=0
CASE_DB_PATH=./data/CaseMatch/cases.sqlite3
CASE_TOP_K=3
CASE_USE_SEMANTIC=true
CASE_LANCEDB_DIR=./data/CaseMatch/lancedb
CASE_VECTOR_TOP_K=5

# --- 记忆压缩 ---
MEMORY_KEEP_RECENT_ROUNDS=3
MEMORY_SUMMARY_TRIGGER_ROUNDS=5
MEMORY_SUMMARY_MAX_CHARS=1500
MEMORY_HISTORY_MAX_TOKENS=4000
MEMORY_COMPRESSION_DEBUG=false

# --- 语义缓存 ---
ENABLE_SEMANTIC_CACHE=true
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_TTL=72
SEMANTIC_CACHE_MAX_ITEMS=1000

# --- 案情分析 ---
ENABLE_CASE_ANALYSIS=true
ANALYSIS_MAX_CLAIMS=5
ANALYSIS_RETRIEVAL_TOP_K=4

# --- 超时配置 ---
LLM_TIMEOUT_SECONDS=15
SSE_KEEPALIVE_SECONDS=15

# --- 接口鉴权 ---
# 聊天/会话写接口鉴权（留空则不鉴权）
CHAT_API_KEY=
# 管理接口鉴权（留空则不鉴权）
ADMIN_API_KEY=

# --- 速率限制 ---
# 窗口内允许的最大请求数（默认 30）
RATE_LIMIT_REQUESTS=30
# 窗口大小，秒（默认 60）
RATE_LIMIT_WINDOW=60
